{
  "$schema": "https://docs.factory.ai/reference/settings-reference",
  "statusLine": {
    "type": "command",
    "command": "node \"$FACTORY_PROJECT_DIR\"/.factory/hooks/statusline.mjs"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Execute",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$FACTORY_PROJECT_DIR\"/.factory/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/.factory/hooks/tldr-read.mjs",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Create|Write|MultiEdit|Update",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/.factory/hooks/post-edit-diagnostics.mjs",
            "timeout": 15
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/.factory/hooks/pre-compact.mjs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$FACTORY_PROJECT_DIR\"/.factory/hooks/auto-handoff-stop.mjs"
          }
        ]
      }
    ]
  }
}
